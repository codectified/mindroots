# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.js

# testing
/coverage

# production
/build

# misc
.env
.DS_Store
.claude/settings.local.json
.env.local
.env.development.local
.env.test.local
.env.production.local

npm-debug.log*
yarn-debug.log*
yarn-error.log*
server.log
*.log

# Runtime data (GPT-created content)
/projects/*
!/projects/.gitkeep
/assets/*
!/assets/.gitkeep

# Workspace tenant data (runtime, not in git)
/workspaces/*/assets/*
/workspaces/*/projects/*

# Shared workspace assets ARE tracked
!/workspaces/_shared/**
